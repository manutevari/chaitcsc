# Environment Configuration Template
# Copy this to .env and fill in actual values (do NOT commit .env).
#
# This file lists exactly the environment variables/Streamlit secrets that
# backend/*.py actually reads (verified by grep against the code, not
# aspirational). If you're deploying to Streamlit Cloud instead of running
# locally with .env, use backend/secrets.toml.txt as the template for
# .streamlit/secrets.toml — same variables, TOML syntax.

# ===================================
# LLM PROVIDERS (backend/llm/config/models.yaml)
# ===================================
# At least one of these is required for cloud AI answers. Voice/fast-mode
# tries Groq first, then Gemini, then Llama 4 Maverick, then the rest —
# see backend/llm/config/routing.yaml for the full priority order, and
# backend/llm/README.md for how the router actually chooses at request time.

HF_TOKEN=YOUR_HUGGINGFACE_TOKEN
HF_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct
HF_BASE_URL=https://router.huggingface.co/v1

OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

GROQ_API_KEY=YOUR_GROQ_KEY
GROQ_MODEL=llama-4-maverick-17b-128e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-3.1-flash-live
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

LLAMA4_MAVERICK_API_KEY=YOUR_OPENROUTER_OR_COMPATIBLE_KEY
LLAMA4_MAVERICK_MODEL=meta-llama/llama-4-maverick
LLAMA4_MAVERICK_BASE_URL=https://openrouter.ai/api/v1

GROK_API_KEY=YOUR_GROK_OR_XAI_KEY
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1

VOICE_LLM_TIMEOUT_SECONDS=6
VOICE_MAX_TOKENS=260
LLM_TIMEOUT_SECONDS=45

# ===================================
# EMBEDDINGS + VECTOR SEARCH (backend/database.py)
# ===================================
# Required for pgvector search. Vector search silently returns no context
# (not an error) if this key is missing — see database.py's _embedding().

OPENAI_API_KEY=YOUR_OPENAI_EMBEDDINGS_KEY

# ===================================
# DATABASE (backend/database.py — Postgres + pgvector)
# ===================================
# These exact names are what the code reads (DB_SECRET_NAMES in
# database.py). A Neon or Supabase pooled-connection string's parts work
# fine here — just split it into these five fields.

DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_DB_PASSWORD

# ===================================
# WEB SEARCH FALLBACK (backend/tavily_search.py)
# ===================================
# Optional. Only used when pgvector + built-in guides both come up empty
# AND the user has given cloud-consent — see mas_engine.ask().

TAVILY_API_KEY=YOUR_TAVILY_KEY

# ===================================
# VOICE (backend/voice_assistant.py)
# ===================================
# Optional. If OPENAI_AUDIO_API_KEY is not set, the app falls back to the
# browser's Web Speech API where supported. Voice here is turn-based
# (record → transcribe → answer → speak), not real-time streaming — see
# AUDIT_REPORT.md for what a real-time upgrade would require.

VOICE_STT_PROVIDER=browser
OPENAI_AUDIO_API_KEY=YOUR_OPENAI_AUDIO_KEY
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ===================================
# ADMIN (pages/6_Admin_Dashboard.py, pages/3_Knowledge_Base.py)
# ===================================
# Keep the admin route private — normal users never see ingestion controls.

CSC_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ===================================
# DPDP / PII CONTROLS (backend/pii_patterns.py, backend/mas_engine.py)
# ===================================

DPDP_REDACTION_ENABLED=true
DPDP_ALLOW_CHILD_DATA_CLOUD=false

# ===================================
# CSC SOURCE GUARDRAIL (backend/guardrails.py)
# ===================================
# Official CSC/gov domains are built into guardrails.py already (70+
# domains). Only add newly verified official domains here, comma-separated.

CSC_ALLOWED_DOMAINS=
CSC_SERVICE_INDEX_LIMIT=12

# ===================================
# INGESTION / CHUNKING (backend/knowledge.py)
# ===================================

PARENT_CHUNK_SIZE=2200
PARENT_CHUNK_OVERLAP=220
CHILD_CHUNK_SIZE=700
CHILD_CHUNK_OVERLAP=140
MAX_CHUNKS_PER_DOCUMENT=80

# ===================================
# HUMAN-IN-THE-LOOP (backend/hitl.py, backend/mas_engine.py)
# ===================================

HITL_ENABLED=true
HITL_CONFIDENCE_THRESHOLD=0.35
HITL_ROUTE_SENSITIVE_QUERIES=true
HITL_QUEUE_DB_PATH=

# ===================================
# NOT USED BY THIS CODEBASE (yet)
# ===================================
# requirements.txt still lists chromadb/fastapi/langgraph/langchain*/
# sqlalchemy as unused dependencies (see CLEANUP_NOTES.md) — there is
# intentionally no ChromaDB path, DATABASE_URL, JWT_SECRET, SMTP, or
# Sentry config here, because nothing in the running app reads them.
# See AUDIT_REPORT.md for what's actually missing vs. what's built.
